{
  "name": "consultegeo-geolab",
  "version": "1.0.0",
  "private": true,
  "description": "Novo Consulte GEO - Controle de Materiais V1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/check-source.mjs && biome lint src && tsc --noEmit && vitest run && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:sql": "bash scripts/run-pgtap.sh",
    "check:source": "node scripts/check-source.mjs",
    "gen:types": "bash scripts/gen-types.sh",
    "seed:tenant": "bash scripts/seed-tenant.sh",
    "deploy:supabase": "bash scripts/deploy-supabase.sh",
    "bump": "node scripts/bump-version.mjs",
    "bundle:ef": "node scripts/bundle-ef.cjs",
    "valida:corpus": "node scripts/valida-corpus.mjs",
    "lint": "biome lint src"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@supabase/supabase-js": "^2.45.4",
    "@tanstack/react-query": "^5.51.23",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.3",
    "date-fns": "^3.6.0",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.80.0",
    "react-router-dom": "^6.28.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@biomejs/biome": "^2.5.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.40",
    "postcss-value-parser": "^4.2.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.5.4",
    "vite": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "@base-ui/react": {
      "date-fns": "$date-fns"
    }
  }
}
